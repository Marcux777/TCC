@article{schmidtDigitalTransformationGrain2025,
  title = {Digital Transformation in Grain Engineering and Post-Harvest Activities: A Case Study and Maturity Model Proposition},
  shorttitle = {Digital Transformation in Grain Engineering and Post-Harvest Activities},
  author = {Schmidt, Daniel and Oelker, Stephan and Engbers, Hendrik and Frazzon, Enzo Morosini and Sellitto, Miguel Afonso},
  date = {2025-11},
  journaltitle = {AgriEngineering},
